<idea-plugin>
    <id>apicopilot</id>
    <name>API Copilot</name>
    <vendor url="https://github.com/lkqm">lkqm</vendor>
    <description><![CDATA[
        Integrating API documentation into the IDE<br>
        Slogan: "Your smart assistant for understanding, navigating, and using APIs — right inside your IDE."<br>
        <p>
            <a href="https://github.com/lkqm/api-copilot">GitHub</a>
        </p>
        <h3>Features</h3>
        <ul>
            <li>Supports OpenAPI, Swagger Hub, Apifox.</li>
            <li>Documentation preview.</li>
            <li>Path completion.</li>
            <li>Jump to documentation from path.</li>
            <li>Generate code.</li>
            <li>More features are developing...</li>
        </ul>

        <h3>Usages</h3>
        <ul>
            <li>Add API document in API tool window.</li>
            <li>Ctrl + \ to search API.</li>
            <li>Typed slash '/' in editor while code completion.</li>
            <li>Ctrl + click jump to API document.</li>
            <li>Right-click to generate code.</li>
        </ul>
    ]]></description>

    <!-- please see https://plugins.jetbrains.com/docs/intellij/build-number-ranges.html for description -->
    <idea-version since-build="222"/>

    <!-- please see https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html
       on how to target different products -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="API Copilot" displayType="BALLOON"/>

        <postStartupActivity implementation="io.apicopilot.startup.AutoRefreshStartupActivity"/>

        <projectService serviceInterface="io.apicopilot.window.ApiView"
                        serviceImplementation="io.apicopilot.window.ApiViewImpl"/>
        <!-- 视图窗口 -->
        <toolWindow id="ApiView" anchor="right" icon="AllIcons.Toolwindows.Documentation" order="last"
                    factoryClass="io.apicopilot.window.ApiViewToolWindowFactory"/>
        <!-- 快速搜索 -->
        <searchEverywhereContributor implementation="io.apicopilot.search.ApiSearchEverywhereContributorFactory"/>

        <!-- 代码提示 -->
        <completion.contributor language="any" order="first"
                                implementationClass="io.apicopilot.editor.completion.PathCompletionContributor"/>
        <completion.confidence language="any" order="before javaSkipAutopopupInStrings"
                               implementationClass="io.apicopilot.editor.completion.PathCompletionConfidence"/>
        <lookup.charFilter implementation="io.apicopilot.editor.completion.PathCompletionCharFilter"/>
        <typedHandler implementation="io.apicopilot.editor.completion.PathCompletionTypedHandler" order="first"/>

        <!-- 路径跳转 -->
        <psi.referenceContributor language="" implementation="io.apicopilot.editor.reference.PathReferenceContributor"/>

        <!-- 文档 -->
        <lang.documentationProvider language=""
                                    implementationClass="io.apicopilot.editor.documentation.ApiDocumentationProvider"/>
    </extensions>

    <actions>
        <!-- Add your actions here -->
        <action id="apicopilot.GotoApiAction" class="io.apicopilot.search.GotoApiAction">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
        </action>

        <group id="ApiViewToolWindowToolbar">
            <group class="io.apicopilot.window.action.AddAction" id="apicopilot.AddAction"/>
            <action class="io.apicopilot.window.action.RemoveAction"/>
            <separator/>
            <action class="io.apicopilot.window.action.RefreshAction"/>
            <action class="io.apicopilot.window.action.PreviewAction"/>"
            <separator/>
            <action class="io.apicopilot.window.action.GenerateCodeAction"/>"
        </group>

        <group id="ApiViewToolbar">
            <action class="io.apicopilot.window.action.LocateApiAction"/>
            <reference ref="ExpandAll"/>
            <reference ref="CollapseAll"/>
        </group>
    </actions>

</idea-plugin>
