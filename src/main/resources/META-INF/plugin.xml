<idea-plugin>
    <id>apicopilot</id>
    <name>Apix</name>
    <vendor url="https://github.com/lkqm">lkqm</vendor>
    <description><![CDATA[
        Apix is an API workbench for JetBrains IDEs.<br>
        <p>
            <a href="https://github.com/lkqm/apix">GitHub</a>
        </p>
        <h3>Features</h3>
        <ul>
            <li>OpenAPI, SwaggerHub, and Apifox document support.</li>
            <li>API tree navigation and documentation preview.</li>
            <li>Quick API search.</li>
            <li>Path completion in string literals.</li>
            <li>Jump to API documentation from paths.</li>
            <li>API request debugging.</li>
            <li>Code generation.</li>
        </ul>

        <h3>Usage</h3>
        <ul>
            <li>Add an API document in the API tool window.</li>
            <li>Press Ctrl + \ to search APIs.</li>
            <li>Type / inside string literals to trigger path completion.</li>
            <li>Use Ctrl + click to jump to API documentation.</li>
            <li>Select APIs and click Generate Code in the API tool window toolbar.</li>
        </ul>
    ]]></description>

    <!-- please see https://plugins.jetbrains.com/docs/intellij/build-number-ranges.html for description -->
    <idea-version since-build="222"/>

    <!-- please see https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html
       on how to target different products -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Apix" displayType="BALLOON"/>

        <postStartupActivity implementation="io.apix.startup.DocumentUpdateStartupActivity"/>

        <projectService serviceInterface="io.apix.window.ApiView"
                        serviceImplementation="io.apix.window.ApiViewImpl"/>
        <projectService serviceImplementation="io.apix.debug.DebugSettings"/>
        <!-- 视图窗口 -->
        <toolWindow id="ApiView" anchor="right" icon="AllIcons.Toolwindows.Documentation" order="last"
                    factoryClass="io.apix.window.ApiViewToolWindowFactory"/>
        <!-- 快速搜索 -->
        <searchEverywhereContributor implementation="io.apix.search.ApiSearchEverywhereContributorFactory"/>

        <!-- 代码提示 -->
        <completion.contributor language="any" order="first"
                                implementationClass="io.apix.editor.completion.PathCompletionContributor"/>
        <completion.confidence language="any" order="before javaSkipAutopopupInStrings"
                               implementationClass="io.apix.editor.completion.PathCompletionConfidence"/>
        <lookup.charFilter implementation="io.apix.editor.completion.PathCompletionCharFilter"/>
        <typedHandler implementation="io.apix.editor.completion.PathCompletionTypedHandler" order="first"/>

        <!-- 路径跳转 -->
        <psi.referenceContributor language="" implementation="io.apix.editor.reference.PathReferenceContributor"/>

        <!-- 文档 -->
        <lang.documentationProvider language=""
                                    implementationClass="io.apix.editor.documentation.ApiDocumentationProvider"/>
    </extensions>

    <actions>
        <!-- Add your actions here -->
        <action id="apix.GotoApiAction" class="io.apix.search.GotoApiAction">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
        </action>

        <group id="ApiViewToolWindowToolbar">
            <group class="io.apix.window.action.AddAction" id="apix.AddAction"/>
            <action class="io.apix.window.action.RemoveAction"/>
            <separator/>
            <action class="io.apix.window.action.RefreshAction"/>
            <action class="io.apix.window.action.PreviewAction"/>
            <separator/>
            <action class="io.apix.window.action.GenerateCodeAction"/>
        </group>

        <group id="ApiViewToolbar">
            <action class="io.apix.window.action.LocateApiAction"/>
            <reference ref="ExpandAll"/>
            <reference ref="CollapseAll"/>
        </group>
    </actions>

</idea-plugin>
