  {
    "name": "OpenFeign",
    "language": "Java",
    "options": [
      { "name": "clientClassName", "type": "text", "required": true, "label":  "Client Class Name", "defaultValue":  "{{#pascal tag}}{{/pascal}}{{#pascal doc}}{{/pascal}}Api"},
      { "name": "clientPackage", "type": "text", "required": true, "label":  "Client Package", "defaultValue":  "client.{{doc}}"},
