      { "name": "serviceUrl", "type": "text", "required": false, "label":  "Service URL"},
      {
        "name": "useLombok",
        "type": "boolean",
        "label": "Use lombok",
        "required": false,
        "defaultValue": "true"
      },
      {
        "name": "serializer",
        "type": "list",
        "label": "Serialization",
        "required": false,
        "defaultValue": "jackson",
        "values": [
          { "value":  "none" },
          { "value":  "jackson" },
          { "value":  "gson" }
        ]
      },
      {
        "name": "responseHandleMode",
        "type": "list",
        "label": "Response Handle Mode",
        "required": false,
        "defaultValue": "raw",
        "values": [
          { "value":  "raw" },
          { "value":  "wrap" },
          { "value":  "unwrap" }
        ]
      },
      { "name": "responseHandleDataField", "type": "text", "required": false, "label":  "Response Data Field"},
      { "name": "responseHandleWrapperClass", "type": "text", "required": false, "label":  "Response Wrapper Class"}
    ],
    "files": [
      { "type": "client", "template": "codegen/code/java/openfeign/client.hbs", "path":  "src/main/java/{{#replace clientPackage '.' '/'}}{{/replace}}/{{{clientClassName}}}.java"},
      { "type": "model", "template": "codegen/model/java.hbs", "path":  "src/main/java/{{#replace modelPackage '.' '/'}}{{/replace}}/{{{modelName}}}.java"}
    ]
  },
