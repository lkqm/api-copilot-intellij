[
  {
    "name": "default",
    "language": "JavaScript",
    "options": [
      { "name": "httpModule", "type": "text", "required": true, "defaultValue": "axios", "label": "Http Module" },
      { "name": "apiFile", "type": "text", "required": true, "defaultValue": "src/api/{{{doc}}}/{{{tag}}}/index.js", "label": "API File" },
      { "name": "typesFile", "type": "text", "required": true, "defaultValue":  "src/api/{{{doc}}}/{{{tag}}}/types.ts", "label":  "Types File"},
      { "name": "exportFile", "type": "text", "required": false, "defaultValue":  "src/api/{{{doc}}}/index.js", "label":  "Export File"},
      {
        "name": "useJsNaming",
        "type": "boolean",
        "label": "Use JavaScript-style names",
        "required": false,
        "defaultValue": false,
        "hidden": true
      },
      {
        "name": "useType",
        "type": "boolean",
        "label": "Use type",
        "required": false,
        "defaultValue": false,
        "hidden": true
      },
      {
        "name": "responseHandleMode",
        "type": "list",
        "label": "Response Handle Mode",
        "required": false,
        "defaultValue": "raw",
        "values": [
          { "value": "raw" },
          { "value": "wrap" },
          { "value": "unwrap" }
        ]
      },
      { "name": "responseHandleDataField", "type": "text", "required": false, "label": "Response Data Field" },
      { "name": "responseHandleWrapperType", "type": "text", "required": false, "label": "Response Wrapper Type" },
      { "name": "responseHandleTypeFile", "type": "text", "required": false, "label": "Response Wrapper Type File" }
    ],
    "files": [
      { "type": "client", "template": "codegen/code/javascript/default/client.hbs", "path": "{{{apiFile}}}" },
      { "type": "models", "template": "codegen/model/typescript.hbs", "path":  "{{{typesFile}}}" },
      { "type": "latest", "template": "codegen/code/javascript/default/export.hbs", "path":  "{{{exportFile}}}" }
    ]
  },
