HttpClient httpClient = HttpClients.createDefault();
String url = "http://127.0.0.1:8080{{path}}";{{#if queryParameters}}
StringBuilder queryParams = new StringBuilder();{{#each queryParameters}}
queryParams.append("{{{this.name}}}=").append("{{this.type}}"){{#unless @last}}.append("&"){{/unless}};{{/each}}
url = url + "?" + queryParams.toString();{{/if}}
Http{{#pascal method}}{{/pascal}} request = new Http{{#pascal method}}{{/pascal}}(url);{{#if headerParameters}}{{#each headerParameters}}
request.addHeader("{{{this.name}}}", "{{this.type}}");{{/each}}{{/if}}{{#if requestBody}}{{#eq requestBodyType 'json'}}
String json = """
{{{this.requestBody.jsonExample}}}
""";
request.setEntity(new StringEntity(json, ContentType.APPLICATION_JSON));{{/eq}}{{#eq requestBodyType 'form'}}
List<NameValuePair> formParams = new ArrayList<>();{{#each requestBodyForm}}
formParams.add(new BasicNameValuePair("{{{this.name}}}", "{{this.type}}"));{{/each}}
request.setEntity(new UrlEncodedFormEntity(formParams));{{/eq}}{{#eq requestBodyType 'form_data'}}
MultipartEntityBuilder builder = MultipartEntityBuilder.create();{{#each requestBodyForm}}{{#neq this.type 'file'}}
builder.addTextBody("{{{this.name}}}", "{{this.type}}", ContentType.TEXT_PLAIN);{{else}}builder.addBinaryBody("{{{this.name}}}", new File("/path/to/file.jpg"), ContentType.IMAGE_JPEG, "file.jpg");{{/neq}}{{/each}}
HttpEntity multipartEntity = builder.build();
request.setEntity(multipartEntity);{{/eq}}{{#eq requestBodyType 'binary'}}
File file = new File("path/to/your/file");
FileEntity fileEntity = new FileEntity(file, ContentType.APPLICATION_OCTET_STREAM);
request.setEntity(fileEntity);{{/eq}}{{/if}}
try (CloseableHttpResponse response = httpClient.execute(request)) {
    int statusCode = response.getCode();
    HttpEntity responseEntity = response.getEntity();
    if (statusCode >= 200 && statusCode < 300) {
        String responseBody=EntityUtils.toString(responseEntity); System.out.println("Response body: " + responseBody);
    } else {
        System.err.println(" HTTP error: " + statusCode);
    }
} catch (IOException e) {
    e.printStackTrace();
} 